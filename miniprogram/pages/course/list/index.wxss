/* 选课页 */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f8f9fa;
}

/* 自定义导航栏 */
.custom-nav {
  padding: 24rpx 32rpx 16rpx;
  background: linear-gradient(to bottom, #eff6ff, #f8f9fa);
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: #fff;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 999rpx;
  padding: 14rpx 24rpx;
}

.search-icon {
  font-size: 26rpx;
  margin-right: 10rpx;
  opacity: 0.4;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

.filter-btn {
  margin-left: 20rpx;
  padding: 8rpx;
}

.filter-icon {
  font-size: 36rpx;
  color: #666;
}

/* 主体布局 */
.main {
  flex: 1;
  display: flex;
  overflow: hidden;
  margin-bottom: 160rpx;
}

/* 左侧分类侧边栏 */
.sidebar {
  width: 160rpx;
  background: #f8f9fa;
  flex-shrink: 0;
  height: 100%;
}

.sidebar-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.sidebar-item.active {
  background: #fff;
  color: #2563EB;
  font-weight: bold;
}

.sidebar-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background: #2563EB;
  border-radius: 0 4rpx 4rpx 0;
}

/* 右侧课程列表 */
.course-list {
  flex: 1;
  width: 0;
  min-width: 0;
  height: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.course-card {
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.cover-wrapper {
  position: relative;
  width: 100%;
}

.course-cover {
  width: 100%;
  height: 200rpx;
  display: block;
}

.category-badge {
  position: absolute;
  top: 0;
  right: 0;
  background: linear-gradient(135deg, #2563EB, #3b82f6);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx 6rpx 20rpx;
  border-radius: 0 32rpx 0 16rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.course-info {
  padding: 20rpx 24rpx 24rpx;
}

.course-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.course-meta {
  font-size: 24rpx;
  color: #2563EB;
  font-weight: 500;
}

.trial-btn {
  background: linear-gradient(135deg, #2563EB, #3b82f6);
  border-radius: 999rpx;
  padding: 8rpx 24rpx;
  flex-shrink: 0;
}

.trial-btn-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.loading-tip {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #ccc;
}
