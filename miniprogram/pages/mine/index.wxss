/* 退出登录 */
.logout-section {
  margin-top: 24rpx;
  padding-bottom: 40rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 32rpx;
  font-size: 30rpx;
  color: #e74c3c;
  font-weight: 500;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}
