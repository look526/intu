<view class="page">
  <view class="header-gradient"></view>

  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{navPaddingTop}}px;">
    <view class="nav-back" bindtap="goBack">
      <view class="back-icon"></view>
    </view>
    <text class="nav-title">消息通知</text>
    <view class="nav-action" wx:if="{{unreadCount > 0}}" bindtap="markAllRead">
      <text class="read-all-text">全部已读</text>
    </view>
    <view class="nav-placeholder" wx:else></view>
  </view>

  <!-- 未登录 -->
  <view wx:if="{{!isLoggedIn}}" class="empty-state">
    <view class="empty-icon">🔔</view>
    <text class="empty-text">登录后查看消息通知</text>
    <view class="empty-btn" bindtap="goLogin">去登录</view>
  </view>

  <!-- 通知列表 -->
  <view wx:elif="{{notifications.length > 0}}" class="notification-list">
    <view
      class="notification-card {{item.isRead ? '' : 'unread'}}"
      wx:for="{{notifications}}"
      wx:key="id"
      data-id="{{item.id}}"
      data-idx="{{index}}"
      bindtap="onTapNotification"
    >
      <!-- 未读圆点 -->
      <view class="unread-dot" wx:if="{{!item.isRead}}"></view>
      <!-- 类型图标 -->
      <view class="type-icon" style="background: {{item.iconColor}};">
        <text class="type-icon-text">{{item.iconText}}</text>
      </view>
      <!-- 内容区 -->
      <view class="notification-body">
        <view class="notification-header">
          <text class="notification-title">{{item.title}}</text>
          <text class="notification-time">{{item.timeAgo}}</text>
        </view>
        <text class="notification-content">{{item.content}}</text>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="load-more" wx:elif="{{!hasMore}}">
      <text>没有更多消息了</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <view class="empty-icon">🔔</view>
    <text class="empty-text">暂无消息</text>
    <text class="empty-sub-text">有新消息时会通知你哦</text>
  </view>
</view>
