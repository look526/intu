/* 消息通知页 */
.page {
  position: relative;
  min-height: 100vh;
  background: #f8f9fa;
}

/* 头部渐变 */
.header-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(to bottom, #eff6ff, #f8f9fa);
  z-index: 0;
}

/* 自定义导航栏 */
.custom-nav {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
}

.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.nav-placeholder {
  width: 64rpx;
}

.nav-action {
  padding: 8rpx 20rpx;
}

.read-all-text {
  font-size: 26rpx;
  color: #2563eb;
}

/* 通知列表 */
.notification-list {
  position: relative;
  z-index: 1;
  padding: 16rpx 32rpx;
}

.notification-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.notification-card.unread {
  background: #fafbff;
  box-shadow: 0 2rpx 16rpx rgba(37, 99, 235, 0.06);
}

/* 未读圆点 */
.unread-dot {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #2563eb;
}

/* 类型图标 */
.type-icon {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.type-icon-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

/* 内容区 */
.notification-body {
  flex: 1;
  min-width: 0;
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.notification-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-time {
  font-size: 22rpx;
  color: #999;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.notification-content {
  font-size: 26rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx 0;
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 240rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-sub-text {
  font-size: 24rpx;
  color: #999;
}

.empty-btn {
  margin-top: 40rpx;
  padding: 16rpx 64rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  font-size: 28rpx;
  border-radius: 999rpx;
}
