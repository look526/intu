<view class="page">
  <!-- 头部渐变 -->
  <view class="header-gradient"></view>

  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{navPaddingTop}}px;">
    <view class="nav-back" bindtap="goBack">
      <view class="back-icon"></view>
    </view>
    <text class="nav-title">编辑个人信息</text>
    <view class="nav-placeholder"></view>
  </view>

  <view class="content">
    <!-- 头像区域 -->
    <view class="avatar-section" bindtap="onChooseAvatar">
      <view class="avatar-wrap">
        <image wx:if="{{avatarUrl}}" class="avatar" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-placeholder-text">{{nickname[0] || '趣'}}</text>
        </view>
        <view class="avatar-edit-badge">
          <text class="edit-icon-text">📷</text>
        </view>
      </view>
      <text class="avatar-tip">点击更换头像</text>
    </view>

    <!-- 表单区域 -->
    <view class="form-card">
      <!-- 昵称 -->
      <view class="form-item">
        <text class="form-label">昵称</text>
        <input class="form-input" value="{{nickname}}" bindinput="onNicknameInput" placeholder="请输入昵称" maxlength="20" />
      </view>

      <view class="form-divider"></view>

      <!-- 手机号 -->
      <view class="form-item">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" value="{{phone}}" bindinput="onPhoneInput" placeholder="请输入手机号" maxlength="11" />
      </view>
    </view>

    <!-- 保存按钮 -->
    <view class="save-btn {{saving ? 'disabled' : ''}}" bindtap="onSave">
      {{saving ? '保存中...' : '保存'}}
    </view>
  </view>
</view>
