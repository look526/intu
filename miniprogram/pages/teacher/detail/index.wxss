/* 教师详情页 */
.page {
  position: relative;
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 160rpx;
}

/* 导航栏 */
.custom-nav {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.04);
}

.back-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.nav-placeholder {
  width: 64rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #bbb;
  font-size: 28rpx;
}

.detail-content {
  /* content wrapper */
}

/* ===== 个人名片卡 ===== */
.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  margin: 0 32rpx;
  border-radius: 32rpx;
  padding: 48rpx 32rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  background: #f0f0f0;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  margin-bottom: 20rpx;
}

.profile-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.profile-avatar-text {
  font-size: 56rpx;
  color: #fff;
  font-weight: bold;
}

.profile-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 10rpx;
}

.profile-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.profile-rating {
  display: flex;
  align-items: center;
}

.star-icon {
  font-size: 28rpx;
  color: #faad14;
  margin-right: 4rpx;
}

.rating-value {
  font-size: 28rpx;
  color: #faad14;
  font-weight: bold;
}

.profile-meta-sep {
  margin: 0 12rpx;
  color: #ccc;
  font-size: 24rpx;
}

.profile-years {
  font-size: 24rpx;
  color: #666;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.spec-tag {
  padding: 6rpx 20rpx;
  background: rgba(37, 99, 235, 0.08);
  color: #2563EB;
  font-size: 22rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

/* 数据统计 */
.profile-stats {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 24rpx 0 0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #2563EB;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #e0e0e0;
}

/* ===== 通用板块 ===== */
.section {
  background: #fff;
  margin-top: 20rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  margin-left: 32rpx;
  margin-right: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  display: block;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 4rpx;
  width: 6rpx;
  height: 32rpx;
  background: #2563EB;
  border-radius: 3rpx;
}

/* 个人简介 */
.bio-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  display: block;
}

.bio-collapsed {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.bio-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 16rpx;
}

.toggle-text {
  font-size: 24rpx;
  color: #2563EB;
}

.toggle-arrow {
  font-size: 24rpx;
  color: #2563EB;
  margin-left: 6rpx;
}

/* 视频 */
.video-wrap {
  border-radius: 20rpx;
  overflow: hidden;
}

.intro-video {
  width: 100%;
  height: 400rpx;
  border-radius: 20rpx;
}

/* 证书横向滚动 */
.gallery-scroll {
  white-space: nowrap;
}

.gallery-scroll::-webkit-scrollbar {
  display: none;
}

.gallery-img {
  display: inline-block;
  width: 280rpx;
  height: 200rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  background: #f0f0f0;
}

/* 作品集网格 */
.portfolio-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.portfolio-img {
  width: calc(33.33% - 8rpx);
  height: 220rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

/* 开设课程 */
.course-list {
  /* no padding needed */
}

.course-card {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.course-card:last-child {
  border-bottom: none;
}

.course-cover {
  width: 140rpx;
  height: 100rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.course-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
}

.cover-placeholder-text {
  font-size: 32rpx;
  color: #2563EB;
  font-weight: bold;
}

.course-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.course-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-meta {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 6rpx;
}

.course-desc {
  font-size: 22rpx;
  color: #bbb;
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ===== 底部操作栏 ===== */
.action-bar {
  position: fixed;
  bottom: 24rpx;
  left: 32rpx;
  right: 32rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  padding: 12rpx 16rpx;
  z-index: 100;
  bottom: calc(24rpx + constant(safe-area-inset-bottom));
  bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-consult {
  width: 140rpx;
  flex-shrink: 0;
  background: rgba(37, 99, 235, 0.08);
  color: #2563EB;
  gap: 6rpx;
}

.btn-consult-icon {
  font-size: 28rpx;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #2563EB, #1d4ed8);
  color: #fff;
}
