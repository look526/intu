.page {
  min-height: 100vh;
  background: #f5f6fa;
  position: relative;
}

.header-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(to bottom, #eff6ff, #f5f6fa);
  z-index: 0;
}

/* 自定义导航栏 */
.custom-nav {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx 16rpx;
}

.nav-back {
  margin-right: 16rpx;
  padding: 8rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

/* ===== 审核状态页 ===== */
.status-page {
  position: relative;
  z-index: 1;
  padding: 80rpx 32rpx;
}

.status-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
}

.status-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.approved-bg { background: rgba(82, 196, 26, 0.1); }
.rejected-bg { background: rgba(255, 77, 79, 0.1); }

.status-emoji {
  font-size: 60rpx;
}

.status-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.status-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.reject-reason {
  background: #fff5f5;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin: 20rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.reject-label {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.reject-text {
  font-size: 26rpx;
  color: #666;
}

.reapply-btn {
  margin-top: 32rpx;
  padding: 20rpx 80rpx;
  background: #2563EB;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* ===== Hero 待审核 ===== */
.hero-pending {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(160deg, #1e3a5f 0%, #2563EB 50%, #3b82f6 100%);
  border-radius: 32rpx;
  padding: 80rpx 40rpx 48rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(37, 99, 235, 0.3);
}

.hero-glow {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-badge {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  backdrop-filter: blur(10px);
}

.hero-badge-icon {
  font-size: 72rpx;
}

.hero-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
}

.hero-divider {
  width: 80rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 4rpx;
  margin-bottom: 32rpx;
}

.hero-quote {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 2;
  text-align: center;
  font-style: italic;
  margin-bottom: 40rpx;
  padding: 0 16rpx;
}

.hero-info-col {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}

.hero-info-item {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  backdrop-filter: blur(10px);
}

.hero-info-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ===== 表单 ===== */
.form-scroll {
  position: relative;
  z-index: 1;
  padding: 16rpx 32rpx;
  height: calc(100vh - 120rpx);
  box-sizing: border-box;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.card-hint {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
  margin-top: -8rpx;
}

.required {
  color: #ff4d4f;
  font-size: 26rpx;
}

.optional {
  color: #999;
  font-size: 24rpx;
  font-weight: normal;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  line-height: 88rpx;
}

.placeholder {
  color: #bbb;
}

.picker-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.location-info {
  padding: 8rpx 0 16rpx;
}

.location-text {
  font-size: 22rpx;
  color: #2563EB;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

/* ===== 图片网格 ===== */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.grid-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.grid-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
}

.grid-add {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-plus {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
}

.remove-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* ===== 提交按钮 ===== */
.submit-btn {
  text-align: center;
  padding: 24rpx 0;
  background: #2563EB;
  color: #fff;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

.submit-btn.disabled {
  background: #ccc;
}
