/* ===== 评论区 ===== */
.comment-section {
  margin-top: 16rpx;
  background: #fff;
  padding: 0 32rpx;
}

.section-header {
  padding: 28rpx 0 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.c-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.c-body {
  flex: 1;
}

.c-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.c-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.c-time {
  font-size: 22rpx;
  color: #bbb;
}

.c-text {
  font-size: 28rpx;
  color: #1a1a1a;
  line-height: 1.6;
}

.comment-empty {
  text-align: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #bbb;
}

/* ===== 推荐笔记 ===== */
.recommend-section {
  margin-top: 16rpx;
  background: #fff;
  padding: 0 32rpx;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 24rpx;
}

.recommend-card {
  display: flex;
  background: #f8f9fa;
  border-radius: 20rpx;
  overflow: hidden;
}

.rec-cover {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.rec-content {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.rec-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.rec-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rec-author {
  font-size: 22rpx;
  color: #999;
}

.rec-likes {
  font-size: 22rpx;
  color: #999;
}

/* ===== 底部评论栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  gap: 16rpx;
}

.bar-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

.send-btn {
  background: #2563EB;
  color: #fff;
  font-size: 28rpx;
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  white-space: nowrap;
}

.send-btn.disabled {
  background: #ccc;
}
