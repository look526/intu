/* 笔记详情 - 传统模式 */
.page {
  width: 100vw;
  min-height: 100vh;
  background: #f8f9fa;
}

/* ===== 自定义导航栏 ===== */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
  background: linear-gradient(to bottom, #eff6ff, #f8f9fa);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
}

.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.nav-placeholder {
  width: 64rpx;
}

/* ===== 主体滚动区 ===== */
.main-scroll {
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
}

/* ===== 作者卡片 ===== */
.author-card {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  margin-bottom: 2rpx;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.author-time {
  font-size: 22rpx;
  color: #999;
}

.course-chip {
  display: inline-flex;
  align-items: center;
  background: rgba(37, 99, 235, 0.08);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.chip-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #2563EB;
  margin-right: 10rpx;
}

.chip-text {
  font-size: 22rpx;
  color: #2563EB;
  font-weight: 500;
}

/* ===== 笔记正文 ===== */
.note-body {
  background: #fff;
  padding: 32rpx;
  font-size: 32rpx;
  color: #333;
  line-height: 2;
  white-space: pre-wrap;
  word-break: break-all;
}

/* ===== 图片列表 ===== */
.note-images {
  background: #fff;
  padding: 0 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.note-img {
  width: 100%;
  border-radius: 16rpx;
}

/* ===== 互动数据行 ===== */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 16rpx;
  margin-top: 2rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.stat-item {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  gap: 8rpx;
  padding: 12rpx 0;
  border-radius: 999rpx;
  background: transparent;
  border: none;
  line-height: 1;
  margin: 0;
  min-height: 0;
}

.stat-item::after {
  display: none;
}

.stat-item.active .stat-text {
  color: #2563EB;
}

.share-btn-inline {
  display: flex !important;
  align-items: center;
  justify-content: center;
  flex: 1;
  font-size: 0;
  min-height: 0;
  gap: 8rpx;
}

.stat-icon {
  width: 36rpx;
  height: 36rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.stat-text {
  font-size: 24rpx;
  color: #666;
}

