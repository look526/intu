<view class="page">
  <view class="header-gradient"></view>

  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{navPaddingTop}}px;">
    <view class="nav-back" bindtap="goBack">
      <view class="back-icon"></view>
    </view>
    <text class="nav-title">我的笔记</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 笔记列表 -->
  <view class="note-cards" wx:if="{{notes.length > 0}}">
    <view class="note-card" wx:for="{{notes}}" wx:key="id">
      <view class="card-body" bindtap="goDetail" data-id="{{item.id}}">
        <!-- 左侧内容 -->
        <view class="note-content">
          <text class="note-text">{{item.contentPreview}}</text>
          <view class="note-tags">
            <text class="tag tag-course" wx:if="{{item.courseName}}">{{item.courseName}}</text>
            <text class="tag tag-class" wx:if="{{item.classGroupName}}">{{item.classGroupName}}</text>
          </view>
          <view class="note-meta">
            <view class="meta-stats">
              <view class="note-action">
                <view class="action-svg svg-heart"></view>
                <text>{{item.likes}}</text>
              </view>
              <view class="note-action">
                <view class="action-svg svg-comment"></view>
                <text>{{item.comments}}</text>
              </view>
            </view>
            <text class="meta-date">{{item.dateStr}}</text>
          </view>
        </view>
        <!-- 右侧封面图 -->
        <image
          wx:if="{{item.coverImage}}"
          class="note-cover"
          src="{{item.coverImage}}"
          mode="aspectFill"
        />
      </view>
      <view class="card-footer">
        <view class="footer-left">
          <text class="image-count" wx:if="{{item.imageCount > 0}}">{{item.imageCount}}张图</text>
        </view>
        <view class="delete-btn" catchtap="onDeleteNote" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && notes.length === 0}}">
    <view class="empty-icon-wrap">
      <view class="empty-svg-icon"></view>
    </view>
    <text class="empty-text">还没有发布过笔记</text>
    <view class="empty-btn" bindtap="goPublish">去发布</view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-more" wx:if="{{loading && page > 1}}">
    <text>加载中...</text>
  </view>
  <view class="loading-more" wx:if="{{!hasMore && notes.length > 0}}">
    <text>没有更多了</text>
  </view>

  <!-- 悬浮发布按钮 -->
  <view class="fab-btn" bindtap="goPublish">
    <text class="fab-icon">+</text>
  </view>
</view>
