/* 我的收藏页 */
.page {
  position: relative;
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 40rpx;
}

.header-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(to bottom, #eff6ff, #f8f9fa);
  z-index: 0;
}

/* 自定义导航栏 */
.custom-nav {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
}

.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.nav-placeholder {
  width: 64rpx;
}

/* ===== 笔记卡片列表 ===== */
.note-list {
  position: relative;
  z-index: 1;
  padding: 24rpx 32rpx;
}

.note-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.note-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.note-user {
  display: flex;
  align-items: center;
  flex-shrink: 1;
  min-width: 0;
}

.note-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.note-user-info {
  display: flex;
  flex-direction: column;
}

.note-username {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.note-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.note-course-tag {
  font-size: 22rpx;
  color: #2563EB;
  background: rgba(37, 99, 235, 0.06);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  white-space: nowrap;
  font-weight: 500;
}

.note-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 16rpx;
  word-break: break-all;
}

.line-clamp-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.note-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.note-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
}

/* 操作栏 */
.note-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 8rpx 0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.note-action {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  font-size: 24rpx;
  color: #999;
  gap: 6rpx;
}

.action-svg {
  width: 32rpx;
  height: 32rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

