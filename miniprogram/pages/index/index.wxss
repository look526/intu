/* 首页 */
.page-wrapper {
  position: relative;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.header-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 500rpx;
  background: linear-gradient(to bottom, #eff6ff, #f8f9fa);
  z-index: 0;
}

.container {
  position: relative;
  z-index: 1;
}

/* 自定义导航栏 */
.custom-nav {
  position: relative;
  z-index: 1;
  padding: 24rpx 32rpx 16rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 999rpx;
  padding: 18rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.4;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

/* Banner 轮播 */
.banner-swiper {
  width: 100%;
  height: 320rpx;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
}

.banner-overlay {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
  background: linear-gradient(to top, rgba(0,0,0,0.35), transparent);
  border-radius: 0 0 32rpx 32rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.banner-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 金刚区分类 */
.categories {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  margin-bottom: 32rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
}

.category-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.category-icon-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.category-icon-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

/* 推荐课程 Header */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999;
}

.arrow {
  margin-left: 4rpx;
  font-size: 24rpx;
}

/* 课程卡片 */
.course-list {
  padding-bottom: 20rpx;
}

.course-card {
  display: flex;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.course-cover-wrap {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
}

.course-cover {
  width: 100%;
  height: 100%;
}

.course-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #fff;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  min-width: 0;
}

.course-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 8rpx;
}

.course-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.course-price {
  font-size: 34rpx;
  font-weight: bold;
  color: #f5a623;
}

.course-enroll {
  display: flex;
  align-items: center;
}

.enroll-icon-text {
  font-size: 24rpx;
  margin-right: 6rpx;
  opacity: 0.5;
}

.enroll-count {
  font-size: 24rpx;
  color: #2463eb;
}

/* 优秀教师 */
.teacher-scroll {
  white-space: nowrap;
  padding: 0 0 32rpx;
  margin-bottom: 8rpx;
}

.teacher-scroll::-webkit-scrollbar {
  display: none;
}

.teacher-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 280rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx 20rpx 24rpx;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.teacher-card:first-child {
  margin-left: 0;
}

.teacher-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  background: #f0f0f0;
}

.teacher-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 240rpx;
}

.teacher-spec {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 240rpx;
}

.teacher-rating {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.rating-star {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.rating-num {
  font-size: 24rpx;
  color: #f5a623;
  font-weight: bold;
}

.teacher-courses {
  font-size: 20rpx;
  color: #2563EB;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 240rpx;
}

/* 优秀班级 */
.rank-filter {
  white-space: nowrap;
  padding: 0 0 20rpx;
}

.rank-filter::-webkit-scrollbar {
  display: none;
}

.filter-tag {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #666;
  background: #f0f0f0;
  margin-right: 16rpx;
}

.filter-tag.active {
  background: #2563EB;
  color: #fff;
}

.ranking-list {
  padding-bottom: 20rpx;
}

.ranking-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.rank-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  background: #ccc;
  flex-shrink: 0;
  margin-right: 20rpx;
  text-align: center;
  line-height: 56rpx;
}

.rank-1 {
  background: linear-gradient(135deg, #FFD700, #FFA000);
}

.rank-2 {
  background: linear-gradient(135deg, #C0C0C0, #9E9E9E);
}

.rank-3 {
  background: linear-gradient(135deg, #CD7F32, #A0522D);
}

.rank-default {
  background: #ddd;
  color: #999;
}

.rank-info {
  flex: 1;
  min-width: 0;
}

.rank-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-course {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-stats {
  display: flex;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.rank-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 24rpx;
}

.stat-val {
  font-size: 28rpx;
  font-weight: bold;
  color: #2563EB;
}

.stat-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.empty-ranking {
  padding: 60rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #ccc;
}
