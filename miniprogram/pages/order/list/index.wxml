<view class="page">
  <view class="header-gradient"></view>

  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{navPaddingTop}}px;">
    <view class="nav-back" bindtap="goBack">
      <view class="back-icon"></view>
    </view>
    <text class="nav-title">我的订单</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 顶部 Tab -->
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'tab-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabChange"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-cards" wx:if="{{orders.length > 0}}">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="card-header">
        <text class="order-no">订单号: {{item.id}}</text>
        <text class="status-tag status-{{item.status}}">
          {{item.status === 'pending' ? '待付款' : item.status === 'paid' ? '已付款' : '已取消'}}
        </text>
      </view>
      <view class="card-body">
        <image
          class="course-thumb"
          src="{{item.course.coverImage || '/assets/tabbar/course.png'}}"
          mode="aspectFill"
        />
        <view class="course-info">
          <text class="course-name">{{item.course.name}}</text>
          <text class="course-meta">{{item.course.totalHours}} 课时</text>
          <text class="course-price">¥{{item.amount}}</text>
        </view>
      </view>
      <view class="card-footer" wx:if="{{item.status === 'pending'}}">
        <view class="cancel-btn" catchtap="onCancelOrder" data-id="{{item.id}}">取消订单</view>
        <view class="pay-btn" catchtap="goDetail" data-id="{{item.id}}">去付款</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
    <view class="empty-icon-wrap">
      <view class="empty-svg-icon"></view>
    </view>
    <text class="empty-text">暂无订单</text>
    <view class="empty-btn" bindtap="goSelectCourse">去选课</view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-more" wx:if="{{loading && page > 1}}">
    <text>加载中...</text>
  </view>
  <view class="loading-more" wx:if="{{!hasMore && orders.length > 0}}">
    <text>没有更多了</text>
  </view>
</view>
