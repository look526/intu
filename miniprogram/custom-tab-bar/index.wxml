<view class="tab-bar">
  <view
    class="tab-item {{selected === index ? 'active' : ''}}"
    wx:for="{{list}}"
    wx:key="index"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon {{selected === index ? 'icon-active-' + index : 'icon-' + index}}"></view>
    <text class="tab-label">{{item.text}}</text>
  </view>
</view>
